########################################
# Core app
########################################
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/appointly
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

########################################
# Public/frontend URLs used in emails/links
# Set at least one of these in production.
########################################
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

########################################
# CORS
# Comma-separated list, no trailing slash
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
########################################
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false

########################################
# Email (optional in dev)
# If SMTP host is missing, app may log verification code to console in dev.
# Primary keys: SMTP_*
# Supported aliases in code: EMAIL_HOST, EMAIL_USER, EMAIL_PASS, EMAIL_PORT, EMAIL_SECURE
########################################
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Appointly <noreply@yourdomain.com>"

########################################
# Cloudinary (required for image uploads on Vercel/serverless)
########################################
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

########################################
# Optional behavior tuning
########################################
BOOKING_PENDING_HOLD_MINUTES=5
SLOT_HOLD_MINUTES=3
GEOCODER_USER_AGENT=appointly/1.0 (contact@example.com)

########################################
# Rate limiting
########################################
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=900000
RATE_LIMIT_PASSWORD_RESET_MAX=8
RATE_LIMIT_BOOKING_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_BOOKING_PUBLIC_MAX=40
RATE_LIMIT_BOOKING_ACCOUNT_WINDOW_MS=60000
RATE_LIMIT_BOOKING_ACCOUNT_MAX=80
RATE_LIMIT_SUBSCRIPTION_WINDOW_MS=900000
RATE_LIMIT_SUBSCRIPTION_MAX=10
