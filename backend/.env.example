PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/appointly

# Email (optional in dev — if no SMTP host, verification code is printed to the console)
# You need a HOST (mail server). User/password alone are not enough.
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Aliases also work: EMAIL_HOST, EMAIL_USER, EMAIL_PASS (same values as above)
EMAIL_FROM="Appointly <noreply@yourdomain.com>"

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS (comma-separated list, no trailing slash)
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=900000
RATE_LIMIT_PASSWORD_RESET_MAX=8
RATE_LIMIT_BOOKING_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_BOOKING_PUBLIC_MAX=40
RATE_LIMIT_BOOKING_ACCOUNT_WINDOW_MS=60000
RATE_LIMIT_BOOKING_ACCOUNT_MAX=80
RATE_LIMIT_SUBSCRIPTION_WINDOW_MS=900000
RATE_LIMIT_SUBSCRIPTION_MAX=10
